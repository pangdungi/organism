# 슈퍼 계정 (이 아이디/비번으로 로그인 가능)
VITE_SUPER_ID=your_super_email@example.com
VITE_SUPER_PW=your_super_password

# Supabase (https://supabase.com 가입 후 프로젝트 생성)
# 프로젝트 설정 → API에서 URL과 anon key 복사
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Web Push (할일 리마인더) — `npx web-push generate-vapid-keys` 로 생성한 공개 키만 프론트에 둡니다.
# 비밀 키는 Supabase Edge Function `send-reminder-pushes` Secrets(VAPID_PRIVATE_KEY 등)에만 넣으세요.
# 배포(Vercel): VITE_VAPID_PUBLIC_KEY 또는 VAPID_PUBLIC_KEY 로 설정. 빌드 로그 source: env 가 아니면 env 미전달.
# 그래도 length 0 이면 src/vapid-public.build.json 의 "publicKey"에 공개 키를 직접 넣고 커밋(공개키만, 비밀키 금지).
VITE_VAPID_PUBLIC_KEY=BGx...
